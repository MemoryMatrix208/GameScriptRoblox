local MainTab = Window:CreateTab("Money", "rbxassetid://125367160504472")

local p=game:GetService("Players").LocalPlayer
local rs=game:GetService("RunService")

local mode=0
local conn

local function hrp()
    local c=p.Character or p.CharacterAdded:Wait()
    return c:WaitForChild("HumanoidRootPart")
end

local function getMyPlot()
    local plots=workspace:FindFirstChild("PlotSystem")
        and workspace.PlotSystem:FindFirstChild("Plots")
    if not plots then return end

    return plots:FindFirstChild(p.Name)
end

local function collect()
    local r=hrp()
    local plot=getMyPlot()
    if not plot then return end

    local stands=plot:FindFirstChild("Stands")
    if not stands then return end

    for _,stand in pairs(stands:GetChildren())do
        local claim=stand:FindFirstChild("Claim")
        if claim and claim:IsA("Model") then
            
            local part=claim.PrimaryPart or claim:FindFirstChildWhichIsA("BasePart")
            if part then
                r.CFrame=part.CFrame+Vector3.new(0,2,0)
                task.wait(.05)

                local pr=claim:FindFirstChildWhichIsA("ProximityPrompt",true)
                if pr then
                    fireproximityprompt(pr)
                else
                    firetouchinterest(r,part,0)
                    firetouchinterest(r,part,1)
                end
            end

        end
    end
end

local function startLoop()
    if conn then conn:Disconnect() end
    conn=rs.Heartbeat:Connect(function()
        collect()
        task.wait(.3)
    end)
end

local function stopLoop()
    if conn then conn:Disconnect() conn=nil end
end

Window:AddButton(MainTab,"Auto Collect Money","Mode","rbxassetid://125367160504472",function()
    mode=(mode+1)%3

    if mode==0 then
        stopLoop()
        collect()
        Window:Notify({
            Title="Auto Collect",
            Description="Mode: Once",
            Content="Collect your plot",
            Color=Color3.fromRGB(0,255,255),
            Delay=2
        })

    elseif mode==1 then
        startLoop()
        Window:Notify({
            Title="Auto Collect",
            Description="Mode: Loop",
            Content="Auto Collect your plot...",
            Color=Color3.fromRGB(0,255,255),
            Delay=2
        })

    else
        stopLoop()
        Window:Notify({
            Title="Auto Collect",
            Description="Mode: Stop",
            Content="Stopped",
            Color=Color3.fromRGB(0,255,255),
            Delay=2
        })
    end
end)

