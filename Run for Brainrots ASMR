local function collect()
    local r=hrp()

    local startPos=CFrame.new(-12.258, 3.980, -6990.211)
    local endPos=CFrame.new(-17.993,4.775,-73.255)

    local br=workspace:FindFirstChild("Map")
        and workspace.Map:FindFirstChild("MainMap")
        and workspace.Map.MainMap:FindFirstChild("Hub")
        and workspace.Map.MainMap.Hub:FindFirstChild("StageLava")
        and workspace.Map.MainMap.Hub.StageLava:FindFirstChild("acid10")
        and workspace.Map.MainMap.Hub.StageLava.acid10:FindFirstChild("Brainrots")

    if not br then return end

    
    r.CFrame=startPos
    task.wait(.2)

    for _,m in pairs(br:GetChildren())do
        if m:IsA("Model") then
            local part=m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart")
            if part then
                r.CFrame=part.CFrame+Vector3.new(0,2,0)
                task.wait(0.25)

                local pr=m:FindFirstChildWhichIsA("ProximityPrompt",true)
                if pr then
                    fireproximityprompt(pr)
                else
                    firetouchinterest(r,part,0)
                    firetouchinterest(r,part,1)
                end
            end
        end
    end

    
    r.CFrame=endPos
end

