local Main = Window:Section("Player")

local Player = game:GetService("Players").LocalPlayer

local function setSpeed(v)
    local c = Player.Character
    if c then
        local h = c:FindFirstChildOfClass("Humanoid")
        if h then
            h.WalkSpeed = v
        end
    end
end

Main:Button("Speed 100", function() setSpeed(100) end)
Main:Button("Speed 200", function() setSpeed(200) end)
Main:Button("Speed 300", function() setSpeed(300) end)
Main:Button("Speed 400", function() setSpeed(400) end)
Main:Button("Speed 500", function() setSpeed(500) end)
Main:Button("Speed 600", function() setSpeed(600) end)
Main:Button("Speed 700", function() setSpeed(700) end)
Main:Button("Speed 800", function() setSpeed(800) end)
Main:Button("Speed 900", function() setSpeed(900) end)

local Main = Window:Section("Money")

local running = false
local mode = "once"
local Event = game:GetService("ReplicatedStorage").Events.CollectMoney

Main:Button("Auto Collect Money", function()
    if not running then
        if mode == "once" then
            for i = 1,10 do
                Event:FireServer(tostring(i))
            end
            mode = "loop"
        else
            running = true
            task.spawn(function()
                while running do
                    for i = 1,10 do
                        Event:FireServer(tostring(i))
                    end
                    task.wait(0.1)
                end
            end)
        end
    else
        running = false
        mode = "once"
    end
end)

