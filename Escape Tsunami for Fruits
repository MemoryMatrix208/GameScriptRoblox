    Title = "Escape Tsunami for Fruits | ArchiveXNova",
    Accent = Color3.fromRGB(255, 100, 100)
})

local Main = Window:Section("Fruits")

local Player = game:GetService("Players").LocalPlayer

local function tp(v)
    local c = Player.Character
    if c then
        c:PivotTo(CFrame.new(v))
    end
end

