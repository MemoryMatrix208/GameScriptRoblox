local endPos = CFrame.new(-21.005,-167.806,123.906)

local modes = {}
local running = {}

local function collect(index,startPos)
    local spawns = workspace:FindFirstChild("ItemSpawns")
    if not spawns then return end
    local slot = spawns:FindFirstChild(index)
    if not slot then return end

    tp(startPos)
    task.wait(0.2)

    tp(slot.CFrame + Vector3.new(0,2,0))
    task.wait(0.3)

    local item = slot:FindFirstChild("SpawnedItem")
    if not item then return end

    local part = item:FindFirstChildWhichIsA("BasePart")
    if not part then return end

    tp(part.CFrame + Vector3.new(0,2,0))
    task.wait(0.3)

    local pr = item:FindFirstChildWhichIsA("ProximityPrompt",true)
    if pr then
        fireproximityprompt(pr)
        task.wait(0.2)
        fireproximityprompt(pr)
    end

    tp(endPos)
end

local function startLoop(name,index,startPos)
    if running[name] then return end
    running[name] = true
    task.spawn(function()
        while running[name] do
            collect(index,startPos)
            task.wait(0.5)
        end
    end)
end

local function stopLoop(name)
    running[name] = false
end

for _,v in ipairs(data) do
    modes[v[1]] = 0

    Window:AddButton(MainTab,"Auto "..v[1],"","rbxassetid://125367160504472",function()
        modes[v[1]] += 1
        if modes[v[1]] > 2 then modes[v[1]] = 0 end

        if modes[v[1]] == 0 then
            stopLoop(v[1])
            collect(v[2],v[3])

        elseif modes[v[1]] == 1 then
            startLoop(v[1],v[2],v[3])

        elseif modes[v[1]] == 2 then
            stopLoop(v[1])
        end
    end)
end

