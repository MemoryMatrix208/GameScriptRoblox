    if enabled then
        start()
    elseif conn then
        conn:Disconnect()
        conn = nil
    end

    Window:Notify({
        Title = "Infinite Jump",
        Description = enabled and "ENABLED" or "DISABLED",
        Content = "",
        Color = Color3.fromRGB(0,255,255),
        Delay = 3
    })
end)

local MainTab = Window:CreateTab("Money", "rbxassetid://125367160504472")

local p=game:GetService("Players").LocalPlayer

local mode=0
local running=false

local function fireAll()
    local c=p.Character or p.CharacterAdded:Wait()
    local hrp=c and c:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local bases=workspace:FindFirstChild("Bases")
    if not bases then return end

    for _,base in ipairs(bases:GetChildren()) do
        local plot=base:FindFirstChild("Plot")
        if plot then
            for _,floor in ipairs(plot:GetChildren()) do
                if floor.Name:find("Floor") then
                    local platforms=floor:FindFirstChild("Platforms")
                    if platforms then
                        for _,plat in ipairs(platforms:GetChildren()) do
                            local btn=plat:FindFirstChild("Collect")
                            if btn and btn:IsA("BasePart") then
                                firetouchinterest(hrp,btn,0)
                                task.wait(0.05)
                                firetouchinterest(hrp,btn,1)
                            end
                        end
                    end
                end
            end
        end
    end
end

local function fireOnce()
    pcall(fireAll)
end

local function startLoop()
    if running then return end
    running=true
    task.spawn(function()
        while running do
            fireOnce()
            task.wait(0.1)
        end
    end)
end

local function stopLoop()
    running=false
end

Window:AddButton(MainTab,"Auto Collect Cash","","rbxassetid://125367160504472",function()
    mode=mode+1
    if mode>2 then mode=0 end

    if mode==0 then
        stopLoop()
        fireOnce()
        Window:Notify({Title="Cash",Description="ONCE",Content="",Color=Color3.fromRGB(0,255,255),Delay=3})
    elseif mode==1 then
        startLoop()
        Window:Notify({Title="Cash",Description="LOOP",Content="",Color=Color3.fromRGB(0,255,255),Delay=3})
    elseif mode==2 then
        stopLoop()
        Window:Notify({Title="Cash",Description="STOP",Content="",Color=Color3.fromRGB(0,255,255),Delay=3})
    end
end)

