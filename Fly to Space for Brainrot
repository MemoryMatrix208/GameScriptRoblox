    conn = UIS.JumpRequest:Connect(function()
        if enabled then
            local hum = getHum()
            if hum then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end)
end

Window:AddButton(MainTab, "Infinite Jump", "", "rbxassetid://125367160504472", function()
