local MainTab = Window:CreateTab("Brainrots", "rbxassetid://125367160504472")

local p=game:GetService("Players").LocalPlayer
local rs=game:GetService("ReplicatedStorage")
local run=game:GetService("RunService")

local mode=0
local conn

local function tp(cf)
    local c=p.Character or p.CharacterAdded:Wait()
    c:WaitForChild("HumanoidRootPart").CFrame=cf
end

local function getPlotCF()
    local ev=rs:WaitForChild("Events"):WaitForChild("Functions"):WaitForChild("GetPlot")
    local plot=ev:InvokeServer(p)
    if typeof(plot)=="CFrame" then
        return plot
    elseif typeof(plot)=="Instance" then
        local part=plot:FindFirstChildWhichIsA("BasePart",true)
        if part then return part.CFrame end
    end
end

local function collectOne(name)
    local endCF=getPlotCF()
    local entities=workspace:FindFirstChild("Entities")
    if not entities then return end
    local folder=entities:FindFirstChild(name)
    if not folder then return end

    local models={}
    for _,m in ipairs(folder:GetChildren())do
        if m:IsA("Model") then
            table.insert(models,m)
        end
    end

    if #models==0 then return end

    local m=models[math.random(1,#models)]
    local part=m:FindFirstChildWhichIsA("BasePart")

    if part then
        tp(part.CFrame+Vector3.new(0,2,0))
        task.wait(.5)
        local pr=m:FindFirstChildWhichIsA("ProximityPrompt",true)
        if pr then
            fireproximityprompt(pr)
            task.wait(.3)
            fireproximityprompt(pr)
        end
    end

    if endCF then tp(endCF) end
end

local function start(name)
    if conn then conn:Disconnect() end
    conn=run.Heartbeat:Connect(function()
        collectOne(name)
        task.wait(.5)
    end)
end

local function stop()
    if conn then conn:Disconnect() conn=nil end
end

local list={
    "Divine",
    "Secret",
    "Mythical",
    "Legendary",
    "Epic",
    "Rare",
    "Common"
}

for _,name in ipairs(list)do
    Window:AddButton(MainTab,"Auto "..name,"Mode","rbxassetid://125367160504472",function()
        mode=(mode+1)%3

        if mode==0 then
            stop()
            collectOne(name)
            Window:Notify({
                Title=name,
                Description="Mode: Once",
                Content="Collected",
                Color=Color3.fromRGB(0,255,255),
                Delay=2
            })

        elseif mode==1 then
            start(name)
            Window:Notify({
                Title=name,
                Description="Mode: Loop",
                Content="Running...",
                Color=Color3.fromRGB(0,255,255),
                Delay=2
            })

        else
            stop()
            Window:Notify({
                Title=name,
                Description="Mode: Stop",
                Content="Stopped",
                Color=Color3.fromRGB(0,255,255),
                Delay=2
            })
        end
    end)
end

