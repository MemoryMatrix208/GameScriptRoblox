local MainTab = Window:CreateTab("Money", "rbxassetid://125367160504472")

local p = game:GetService("Players").LocalPlayer
local rs = game:GetService("RunService")

local mode = 0
local conn

local function hrp()
    local c = p.Character or p.CharacterAdded:Wait()
    return c:WaitForChild("HumanoidRootPart")
end

local function collect()
    local r = hrp()

    for _, plot in pairs(workspace:GetChildren()) do
        if plot:IsA("Model") and plot.Name:find("Plot_") then
            local floors = plot:FindFirstChild("Floors")
            if floors then
                for _, floor in pairs(floors:GetChildren()) do
                    if floor.Name:find("Floor") then
                        local slots = floor:FindFirstChild("Slots")
                        if slots then
                            for _, slot in pairs(slots:GetChildren()) do
                                local t = slot:FindFirstChild("Collect")
                                if t and t:IsA("BasePart") then
                                    firetouchinterest(r, t, 0)
                                    firetouchinterest(r, t, 1)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end

local function startLoop()
    if conn then conn:Disconnect() end
    conn = rs.Heartbeat:Connect(function()
        collect()
        task.wait(0.3)
    end)
end

local function stopLoop()
    if conn then conn:Disconnect() conn = nil end
end

Window:AddButton(MainTab,"Auto Collect Money","Mode","rbxassetid://125367160504472",function()
    mode = (mode + 1) % 3

    if mode == 0 then
        stopLoop()
        collect()
        Window:Notify({
            Title="Auto Collect",
            Description="Mode: Once",
            Content="Collected once",
            Color=Color3.fromRGB(0,255,255),
            Delay=2
        })

    elseif mode == 1 then
        startLoop()
        Window:Notify({
            Title="Auto Collect",
            Description="Mode: Loop",
            Content="Auto farming...",
            Color=Color3.fromRGB(0,255,255),
            Delay=2
        })

    else
        stopLoop()
        Window:Notify({
            Title="Auto Collect",
            Description="Mode: Stop",
            Content="Stopped",
            Color=Color3.fromRGB(0,255,255),
            Delay=2
        })
    end
end)

