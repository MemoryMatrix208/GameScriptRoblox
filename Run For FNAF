local mainTab = gui:Tab("Money")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local running = false
local mode = "once"

local function collect()
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end

    for i = 1, 8 do
        local plot = plots:FindFirstChild(tostring(i))
        if plot then
            local pads = plot:FindFirstChild("Pads")
            if pads then
                for j = 1, 10 do
                    local pad = pads:FindFirstChild(tostring(j))
                    if pad then
                        local collectPart = pad:FindFirstChild("Collect")
                        if collectPart and collectPart:IsA("BasePart") then
                            firetouchinterest(hrp, collectPart, 0)
                            task.wait()
                            firetouchinterest(hrp, collectPart, 1)
                        end
                    end
                end
            end
        end
    end
end

Azure:CreateButton(mainTab, "Auto Collect Money", "Once / Loop / Stop", function()
    if not running then
        if mode == "once" then
            collect()
            mode = "loop"
        else
            running = true
            task.spawn(function()
                while running do
                    collect()
                    task.wait(0.2)
                end
            end)
        end
    else
        running = false
        mode = "once"
    end
end)
