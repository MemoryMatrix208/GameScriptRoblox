local Azure = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/Home/refs/heads/main/TT"))()

local gui = Azure:Create("AXN")

local mainTab = gui:Tab("FNAF")

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local Player = Players.LocalPlayer

local function tweenTo(cf)
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    local dist = (hrp.Position - cf.Position).Magnitude
    local time = dist / 1000

    local tween = TweenService:Create(
        hrp,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {CFrame = cf}
    )

    tween:Play()
    tween.Completed:Wait()
end

local function collect()
    local posAkhir = CFrame.new(-1221.889, 10.495, 194.482)

    local storage = workspace:FindFirstChild("CharacterStorage")
    if not storage then return end

    local folder = storage:FindFirstChild("Legendary")
    if not folder then return end

    for _, model in pairs(folder:GetChildren()) do
        if model:IsA("Model") then
            local targetCF = model:GetPivot()

            tweenTo(targetCF + Vector3.new(0,3,0))
            task.wait(0.2)

            local prompt = model:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                fireproximityprompt(prompt)
            end

            task.wait(0.2)
            tweenTo(posAkhir)

            break
        end
    end
end

Azure:CreateButton(mainTab, "Auto Legendary (Tween)", "Smooth Collect", function()
    collect()
end)

