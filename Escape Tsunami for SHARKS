local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local running = false
local mode = "once"

local function collectAll()
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end

    for _, plot in pairs(plots:GetChildren()) do
        if plot:IsA("Model") then
            local pedestals = plot:FindFirstChild("Pedestals")
            if pedestals then
                for _, pedestal in pairs(pedestals:GetChildren()) do
                    local part = pedestal:FindFirstChild("Claimpart")
                    if part and part:IsA("BasePart") then
                        firetouchinterest(hrp, part, 0)
                        task.wait()
                        firetouchinterest(hrp, part, 1)
                    end
                end
            end
        end
    end
end

local mainTab = gui:Tab("Money")

Azure:CreateButton(mainTab, "Auto Collect Money", "Once / Loop / Stop", function()
    if not running then
        if mode == "once" then
            collectAll()
            mode = "loop"
        else
            running = true
            task.spawn(function()
                while running do
                    collectAll()
                    task.wait(0.2)
                end
            end)
        end
    else
        running = false
        mode = "once"
    end
end)

