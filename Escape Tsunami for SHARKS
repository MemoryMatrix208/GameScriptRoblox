    local nearest, dist = nil, math.huge

    for _, v in pairs(workspace.ItemSpawnZones:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Parent and v.Parent:IsA("BasePart") then
            local d = (hrp.Position - v.Parent.Position).Magnitude
            if d < dist then
                dist = d
                nearest = v
            end
        end
    end

    if nearest then
        fireproximityprompt(nearest)
    end
end)

