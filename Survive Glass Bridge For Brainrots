local MainTab = Window:CreateTab("Money", "rbxassetid://125367160504472")

local p=game:GetService("Players").LocalPlayer
local rs=game:GetService("RunService")

local mode=0
local conn

local function hrp()
    local c=p.Character or p.CharacterAdded:Wait()
    return c:WaitForChild("HumanoidRootPart")
end

local function collect()
    local r=hrp()
    local plots=workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Plots")
    if not plots then return end

    for _,plot in pairs(plots:GetChildren())do
        if plot:IsA("Model") and plot.Name:find("Plot") then
            for _,floor in pairs(plot:GetChildren())do
                if floor:IsA("Model") and floor.Name:find("Floor") then
                    for _,pad in pairs(floor:GetChildren())do
                        if pad:IsA("Model") and pad.Name:find("Pad") then
                            local btn=pad:FindFirstChild("Button")
                            if btn and btn:IsA("BasePart") then
                                firetouchinterest(r,btn,0)
                                firetouchinterest(r,btn,1)
                            end
                        end
                    end
                end
            end
        end
    end
end

local function startLoop()
    if conn then conn:Disconnect() end
    conn=rs.Heartbeat:Connect(function()
        collect()
        task.wait(.1)
    end)
end

local function stopLoop()
    if conn then conn:Disconnect() conn=nil end
end

Window:AddButton(MainTab,"Auto Collect Money","Mode","rbxassetid://125367160504472",function()
    mode=(mode+1)%3

    if mode==0 then
        stopLoop()
        collect()
        Window:Notify({
            Title="Auto Collect",
            Description="Mode: Once",
            Content="Collected once",
            Color=Color3.fromRGB(0,255,255),
            Delay=2
        })

    elseif mode==1 then
        startLoop()
        Window:Notify({
            Title="Auto Collect",
            Description="Mode: Loop",
            Content="Auto farming...",
            Color=Color3.fromRGB(0,255,255),
            Delay=2
        })

    else
        stopLoop()
        Window:Notify({
            Title="Auto Collect",
            Description="Mode: Stop",
            Content="Stopped",
            Color=Color3.fromRGB(0,255,255),
            Delay=2
        })
    end
end)

