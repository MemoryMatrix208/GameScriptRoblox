local function tweenTo(cf)
    local c=p.Character or p.CharacterAdded:Wait()
    local hrp=c:WaitForChild("HumanoidRootPart")
    local dist=(hrp.Position-cf.Position).Magnitude
    local time=dist/math.max(speedValue,1)
    local tween=ts:Create(hrp,TweenInfo.new(time,Enum.EasingStyle.Linear),{CFrame=cf})
    tween:Play()
    tween.Completed:Wait()
end

local function forcePrompt(pr,part)
    if not pr or not part then return end
    pcall(function()
        pr.Enabled=true
        pr.HoldDuration=0
        pr.RequiresLineOfSight=false
        pr.MaxActivationDistance=math.huge
    end)
    local hrp=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame=part.CFrame+Vector3.new(0,1.5,0)
    end
    for i=1,3 do
        pcall(function() fireproximityprompt(pr) end)
        pcall(function() pr:InputHoldBegin() end)
        pcall(function() pr:InputHoldEnd() end)
        task.wait(0.05)
    end
end

local function collect(name)
    local startPos=CFrame.new(0.521,4.224,-75.295)
    local endPos=CFrame.new(0.521,4.224,-75.295)

    tweenTo(startPos)
    task.wait(0.5)

    local map=workspace:FindFirstChild("Map")
    if not map then return end

    local bridge=map:FindFirstChild("Bridge")
    if not bridge then return end

    local platforms=bridge:FindFirstChild("Platforms")
    if not platforms then return end

    local rarityFolder=platforms:FindFirstChild(name)
    if not rarityFolder then return end

    local brainrots=rarityFolder:FindFirstChild("Brainrots")
    if not brainrots then return end

    local found=false

    for _,item in pairs(brainrots:GetChildren())do
        local part=item:IsA("Model") and item:FindFirstChildWhichIsA("BasePart") or item
        if part and part:IsA("BasePart") then
            found=true
            tweenTo(part.CFrame+Vector3.new(0,2,0))
            task.wait(0.1)
            local pr=item:FindFirstChildWhichIsA("ProximityPrompt",true)
            if pr then
                forcePrompt(pr,part)
                task.wait(0.2)
            end
        end
    end

    if found then
        task.wait(0.3)
    end

    tweenTo(endPos)

    Window:Notify({
        Title=name,
        Description=found and "Spawn" or "Not Spawn",
        Content=found and "Collected" or "No Brainrots found",
        Color=Color3.fromRGB(0,255,255),
        Delay=3
    })
end

