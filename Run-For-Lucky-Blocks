local Azure = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/Home/refs/heads/main/TT"))()

local gui = Azure:Create("AXN")

local mainTab = gui:Tab("Block")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function tp(cf)
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    hrp.CFrame = cf
end

local function collect()
    local posAkhir = CFrame.new(-87.734, 2.948, -33.611)

    local blocks = workspace:FindFirstChild("Blocks")
    if not blocks then return end

    for _, part in pairs(blocks:GetChildren()) do
        if part.Name == "RareBlock" and part:IsA("BasePart") then

            tp(part.CFrame + Vector3.new(0,2,0))
            task.wait(0.2)

            local prompt = part:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                for i = 1, 2 do
                    fireproximityprompt(prompt)
                    task.wait(0.1)
                end
            end

        end
    end

    tp(posAkhir)
end

Azure:CreateButton(mainTab, "Auto Rare (TP)", "Collect All", function()
    collect()
end)

