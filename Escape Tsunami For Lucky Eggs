local Main = Window:Section("Money")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local running = false
local mode = "once"

local function collectAll()
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")

    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end

    for i = 1, 6 do
        local plot = plots:FindFirstChild("Plot" .. i)
        if plot then
            local pads = plot:FindFirstChild("Pads")
            if pads then
                for j = 1, 10 do
                    local pad = pads:FindFirstChild(tostring(j))
                    if pad then
                        local collect = pad:FindFirstChild("Collect")
                        if collect and collect:IsA("BasePart") then
                            firetouchinterest(hrp, collect, 0)
                            firetouchinterest(hrp, collect, 1)
                        end
                    end
                end
            end
        end
    end
end

Main:Button("Auto Collect Money", function()
    if mode == "once" then
        collectAll()
        mode = "loop"

    elseif mode == "loop" then
        running = true
        mode = "stop"

        task.spawn(function()
            while running do
                collectAll()
                task.wait(0.5)
            end
        end)

    elseif mode == "stop" then
        running = false
        mode = "once"
    end
end)

