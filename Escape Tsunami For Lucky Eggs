local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/MyHomeObf/refs/heads/main/Meow"))()

local Window = Library:CreateWindow({
    Title = "Escape Tsunami For Lucky Eggs | ArchiveXNova",
    Accent = Color3.fromRGB(255, 100, 100)
})

local Main = Window:Section("Brainrot")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function tp(cf)
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    hrp.CFrame = cf
end

Main:Button("Auto OG", function()

    local posAkhir = CFrame.new(127.059, 5.175, -167.219)

    local storage = workspace:FindFirstChild("CharacterStorage")
    local god = storage and storage:FindFirstChild("OG")

    if god then
        local target = god:FindFirstChild("Gold") or god:FindFirstChild("Normal")
        if target then

            local targetCF

            if target:IsA("Model") then
                targetCF = target:GetPivot()
            elseif target:IsA("BasePart") then
                targetCF = target.CFrame
            end

            if targetCF then
                tp(targetCF + Vector3.new(0, 3, 0))
                task.wait(0.25)

                local prompt = target:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    fireproximityprompt(prompt)
                end

                task.wait(0.25)
                tp(posAkhir)
            end
        end
    end

end)

