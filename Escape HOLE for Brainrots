local Azure = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/Home/refs/heads/main/TT"))()

local gui = Azure:Create("AXN")

local mainTab = gui:Tab("Brainrots")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function tp(cf)
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    hrp.CFrame = cf
end

local function collect(folderName, startPos)
    local posAkhir = CFrame.new(284.293, 34.240, 551.376)

    local folder = workspace:FindFirstChild("SpawnableItemsRuntime")
    if not folder then return end

    local rarity = folder:FindFirstChild(folderName)
    if not rarity then return end

    if startPos then
        tp(startPos)
        task.wait(0.25)
    end

    for _, item in pairs(rarity:GetChildren()) do
        if item:IsA("Model") then
            local targetCF = item:GetPivot()

            tp(targetCF + Vector3.new(0,3,0))
            task.wait(0.25)

            local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                fireproximityprompt(prompt)
            end

            task.wait(0.25)
            tp(posAkhir)

            break
        end
    end
end

Azure:CreateButton(mainTab, "Auto Mythic", "Collect Mythic", function()
