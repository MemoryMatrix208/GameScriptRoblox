local mainTab = gui:Tab("Money")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function collect()
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")

    local bases = workspace:FindFirstChild("Bases")
    if not bases then return end

    for _, base in pairs(bases:GetChildren()) do
        local floors = base:FindFirstChild("Floors")
        if floors then
            for _, floor in pairs(floors:GetChildren()) do
                local slots = floor:FindFirstChild("Slots")
                if slots then
                    for _, slot in pairs(slots:GetChildren()) do
                        local touch = slot:FindFirstChild("TouchZone")
                        if touch and touch:IsA("BasePart") then
                            firetouchinterest(hrp, touch, 0)
                            firetouchinterest(hrp, touch, 1)
                        end
                    end
                end
            end
        end
    end
end

Azure:CreateButton(mainTab, "Auto Collect Money", "Collect Money", function()
    collect()
end)

