Azure:CreateButton(mainTab, "Take Manual", "Nearest", function()
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    local nearest, dist = nil, math.huge

    for _, v in pairs(workspace.EntitiesFolder:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Parent and v.Parent:IsA("BasePart") then
            local d = (hrp.Position - v.Parent.Position).Magnitude
            if d < dist then
                dist = d
                nearest = v
            end
        end
    end

    if nearest then
        fireproximityprompt(nearest)
    end
end)

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local running = false
local mode = "once"

local function collectAll()
    local char = Player.Character or Player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    local plots = workspace:FindFirstChild("Plots")
    if not plots then return end

    for _, plot in pairs(plots:GetChildren()) do
        if plot:IsA("Model") then
            local floors = plot:FindFirstChild("Floors")
            if floors then

                for _, floor in pairs(floors:GetChildren()) do
                    if floor:IsA("Folder") or floor:IsA("Model") then

                        local stands = floor:FindFirstChild("Stands")
                        if stands then
                            for _, stand in pairs(stands:GetChildren()) do
                                local cash = stand:FindFirstChild("CashModel")
                                if cash then
                                    local part = cash:FindFirstChild("TouchPart")
                                    if part and part:IsA("BasePart") then
                                        firetouchinterest(hrp, part, 0)
                                        task.wait()
                                        firetouchinterest(hrp, part, 1)
                                    end
                                end
                            end
                        end

                    end
                end

            end
        end
    end
end

