local mainTab = gui:Tab("Money")

Azure:CreateButton(mainTab, "Auto Collect Money", "Once / Loop / Stop", function()
    if not running then
        if mode == "once" then
            collectAll()
            mode = "loop"
        else
            running = true
            task.spawn(function()
                while running do
                    collectAll()
                    task.wait(0.2)
                end
            end)
        end
    else
        running = false
        mode = "once"
    end
end)

