local Azure = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/Home/refs/heads/main/TT"))()

local gui = Azure:Create("AXN")

local mainTab = gui:Tab("Poppy Playtime")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function tp(cf)
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    hrp.CFrame = cf
end

local function collect(folderName)
    local posAkhir = CFrame.new(-62.251, 3.225, 39.501)

    local folder = workspace:FindFirstChild("ItemSpawners")
    if not folder then return end

    local targetFolder = folder:FindFirstChild(folderName)
    if not targetFolder then return end

    local item = targetFolder:FindFirstChild("SpawnedItem")
    if not item then return end

    local targetCF

    if item:IsA("Model") then
        targetCF = item:GetPivot()
    elseif item:IsA("BasePart") then
        targetCF = item.CFrame
    end

    if targetCF then
        tp(targetCF + Vector3.new(0,3,0))
        task.wait(0.25)

        local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            fireproximityprompt(prompt)
        end

        task.wait(0.25)
        tp(posAkhir)
    end
end

Azure:CreateButton(mainTab, "Auto SuperCritters", "Collect SuperCritters", function()
    collect("SuperCritters")
end)

