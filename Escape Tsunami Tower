local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/MyHomeObf/refs/heads/main/Meow"))()

local Window = Library:CreateWindow({
    Title = "Escape Tsunami Tower | ArchiveXNova",
    Accent = Color3.fromRGB(255, 100, 100)
})

local Main = Window:Section("Win")

Main:Button("Auto Win + Coin", function()

    local Players = game:GetService("Players")
    local lp = Players.LocalPlayer
    local target = Vector3.new(-188.867, 51.926, -154.740)

    local delay = 0.2

    _G.WinCoinLoop = not _G.WinCoinLoop

    local function getHRP()
        local char = lp.Character or lp.CharacterAdded:Wait()
        return char:WaitForChild("HumanoidRootPart")
    end

    local function run()
        local hrp = getHRP()
        if hrp then
            hrp.CFrame = CFrame.new(target)
        end

        task.wait(0.1)

        local Event = game:GetService("ReplicatedStorage").Remotes:FindFirstChild("ClaimCoins")
        if Event then
            Event:FireServer()
        end
    end

    if _G.WinCoinLoop then
        task.spawn(function()
            while _G.WinCoinLoop do
                pcall(run)
                task.wait(delay)
            end
        end)
    end

end)

local Main = Window:Section("Coin")

Main:Button("Auto Coins", function()

    local Event = game:GetService("ReplicatedStorage").Remotes:FindFirstChild("Coins")
    local delay = 0.2

    _G.CoinsLoop = not _G.CoinsLoop

    if _G.CoinsLoop then
        task.spawn(function()
            while _G.CoinsLoop do
                if Event then
                    pcall(function()
                        Event:FireServer()
                    end)
                end
                task.wait(delay)
            end
        end)
    end

end)

