    Title = "Aura Slap Troll Tower | ArchiveXNova",
    Accent = Color3.fromRGB(255, 100, 100)
})

local Main = Window:Section("Win")

Main:Button("Auto Win", function()

    local Players = game:GetService("Players")
    local lp = Players.LocalPlayer

    local target = Vector3.new(4102.625, 7.589, 374.015)
    local delay = 0.1

    _G.TeleportLoop = not _G.TeleportLoop

    local function getHRP()
        local char = lp.Character or lp.CharacterAdded:Wait()
        return char:WaitForChild("HumanoidRootPart")
    end

    local function go()
        local hrp = getHRP()
        if hrp then
            hrp.CFrame = CFrame.new(target)
        end
    end

    if _G.TeleportLoop then
        task.spawn(function()
            while _G.TeleportLoop do
                pcall(go)
                task.wait(delay)
            end
        end)
    end

end)

local Main = Window:Section("Slap")

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local running = false
local mode = 1

local function getEvent()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local glove = char:FindFirstChild("NormalGlove")
    return glove and glove:FindFirstChild("Event")
end

local function hitAll()
    local event = getEvent()
    if not event then return end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    event:FireServer("slash", hrp, Vector3.new(0,0,0))
                end
            end
        end
    end
end

Main:Button("Auto Slap", function()
    if mode == 1 then
        hitAll()
        mode = 2

    elseif mode == 2 then
        if not running then
            running = true
            task.spawn(function()
                while running do
                    hitAll()
                    task.wait()
                end
            end)
        end
        mode = 3

    elseif mode == 3 then
        running = false
        mode = 1
    end
end)

