local Azure = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/Home/refs/heads/main/TT"))()

local gui = Azure:Create("AXN")

local mainTab = gui:Tab("Fruits")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function tp(cf)
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    hrp.CFrame = cf
end

local function collect()
    local posAkhir = CFrame.new(-36.668, 3.225, 41.094)

    local folder = workspace:FindFirstChild("ItemSpawns")
    if not folder then return end

    for _, f in pairs(folder:GetChildren()) do
        if f.Name:find("1") then
            local item = f:FindFirstChild("SpawnedItem")
            if item then
                local targetCF

                if item:IsA("Model") then
                    targetCF = item:GetPivot()
                elseif item:IsA("BasePart") then
                    targetCF = item.CFrame
                end

                if targetCF then
                    tp(targetCF + Vector3.new(0,3,0))
                    task.wait(0.25)

                    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if prompt then
                        fireproximityprompt(prompt)
                    end

                    task.wait(0.25)
                    tp(posAkhir)
                end
            end
        end
    end
end

Azure:CreateButton(mainTab, "Auto Common", "Collect Common", function()
    collect()
end)

