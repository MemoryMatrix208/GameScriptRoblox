local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local function collectAll()
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")

    local plot = workspace:FindFirstChild("Plot_" .. Player.Name)
    if not plot then return end

    for _, floor in pairs(plot:GetChildren()) do
        if floor:IsA("Model") and floor.Name:match("^Floor") then
            local slots = floor:FindFirstChild("Slots")
            if slots then
                for _, slot in pairs(slots:GetChildren()) do
                    if slot:IsA("Model") then
                        local collect = slot:FindFirstChild("CollectTouch")
                        if collect and collect:IsA("BasePart") then
                            firetouchinterest(hrp, collect, 0)
                            firetouchinterest(hrp, collect, 1)
                        end
                    end
                end
            end
        end
    end
end

local mainTab = gui:Tab("Money")
Azure:CreateButton(mainTab, "Auto Collect Money", "Collect all money", function()
