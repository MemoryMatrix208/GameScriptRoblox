local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/MyHomeObf/refs/heads/main/Meow"))()

local Window = Library:CreateWindow({
    Title = "Speed Trials Escape | ArchiveXNova",
    Accent = Color3.fromRGB(255, 100, 100)
})

local Main = Window:Section("Win")

local running = false
local mode = "once"

Main:Button("Auto Win In Track 1", function()
    local char = game.Players.LocalPlayer.Character
    if not char then return end

    if not running then
        if mode == "once" then
            char:PivotTo(CFrame.new(-26.681, 9.233, 6442.687))
            mode = "loop"
        else
            running = true
            task.spawn(function()
                while running do
                    local c = game.Players.LocalPlayer.Character
                    if c then
                        c:PivotTo(CFrame.new(-26.681, 9.233, 6442.687))
                    end
                    task.wait()
                end
            end)
        end
    else
        running = false
        mode = "once"
    end
end)

