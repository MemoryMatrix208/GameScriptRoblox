    if c then
        c:PivotTo(CFrame.new(24.763, 796.033, 500.345))
    end
end)

local Main = Window:Section("Slash")

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local running = false
local mode = "once"

Main:Button("Auto Slap", function()
    local char = LocalPlayer.Character
    if not char then return end

    local Event = char.Slap.Event

    local vec = Vector3.new(9999, 9999, 9999)

    if not running then
        if mode == "once" then
            for _,plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    for i = 1,10 do
                        Event:FireServer("slash", plr.Character, vec)
                    end
                end
            end
            mode = "loop"
        else
            running = true
            task.spawn(function()
                while running do
                    for _,plr in ipairs(Players:GetPlayers()) do
                        if plr ~= LocalPlayer and plr.Character then
                            for i = 1,10 do
                                Event:FireServer("slash", plr.Character, vec)
                            end
                        end
                    end
                    task.wait(0.1)
                end
            end)
        end
    else
        running = false
        mode = "once"
    end
end)

