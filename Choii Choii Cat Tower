local Main = Window:Section("VIP And Group")

local function sd(p)
    local o = game
    local r = p
    while r ~= '' do
        local d = r:find('.',1,true)
        local n
        if d then
            n = r:sub(1,d-1)
            r = r:sub(d+1)
        else
            n = r
            r = ''
        end
        o = o:FindFirstChild(n)
        if not o then return end
    end
    if o then o:Destroy() end
end

Main:Button("Remove VIP", function()
    sd("Workspace.Door")
end)

Main:Button("Remove Group", function()
    sd("Workspace.GroupDoor")
end)
