local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/MyHomeObf/refs/heads/main/Meow"))()

local Window = Library:CreateWindow({
    Title = "Escape Tsunami For NBA Players! | ArchiveXNova",
    Accent = Color3.fromRGB(255, 100, 100)
})

local Main = Window:Section("NBA")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function tp(cf)
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    hrp.CFrame = cf
end

local function auto(name,startPos)
    local posAkhir = CFrame.new(17.786, 20.225, -892.965)

    tp(startPos)
    task.wait(0.25)

    local f = workspace:FindFirstChild("ItemSpawners")
        and workspace.ItemSpawners:FindFirstChild(name)

    if f then
        local item = f:FindFirstChild("SpawnedItem")
        if item then
            local targetCF
            if item:IsA("Model") then
                targetCF = item:GetPivot()
            elseif item:IsA("BasePart") then
                targetCF = item.CFrame
            end

            if targetCF then
                tp(targetCF + Vector3.new(0,3,0))
                task.wait(0.25)

                local prompt = item:FindFirstChildWhichIsA("ProximityPrompt",true)
                if prompt then
                    fireproximityprompt(prompt)
                end

                task.wait(0.25)
                tp(posAkhir)
            end
        end
    end
end

