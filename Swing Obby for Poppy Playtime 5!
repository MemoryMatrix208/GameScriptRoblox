local Azure = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/Home/refs/heads/main/TT"))()

local gui = Azure:Create("AXN")

local mainTab = gui:Tab("Poppy Playtime")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function tp(cf)
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    hrp.CFrame = cf
end

local function collect()
    local startPos = CFrame.new(-1.787, 3.000, 2785.850)
    local posAkhir = CFrame.new(41.386, 3.000, 27.928)

    tp(startPos)
    task.wait(0.25)

    local spawn = workspace:FindFirstChild("ItemSpawns")
        and workspace.ItemSpawns:FindFirstChild("6")

    if spawn then
        local item = spawn:FindFirstChild("SpawnedItem")
        if item then

            local targetCF = item:GetPivot()
            tp(targetCF + Vector3.new(0,3,0))
            task.wait(0.25)

            local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                fireproximityprompt(prompt)
            end

            task.wait(0.25)
            tp(posAkhir)

        end
    end
end

Azure:CreateButton(mainTab, "Auto Secret, Mythical, Legendary, Epic", "Collect Secret, Mythical, Legendary, Epic", function()
    collect()
end)

