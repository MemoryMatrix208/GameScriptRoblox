local Main = Window:Section("Money")

local running = false
local loopMode = false

local function getPlot()
    local name = game.Players.LocalPlayer.Name
    for _,v in pairs(workspace:GetChildren()) do
        if v:IsA("Model") and string.find(v.Name, name) then
            return v
        end
    end
end

local function collectOnce()
    local plot = getPlot()
    if not plot then return end

    for i = 1,3 do
        local floor = plot:FindFirstChild("Floor"..i)
        if floor then
            local slots = floor:FindFirstChild("Slots")
            if slots then
                for s = 1,10 do
                    local slot = slots:FindFirstChild("Slot"..s)
                    if slot then
                        local touch = slot:FindFirstChild("CollectTouch")
                        if touch then
                            firetouchinterest(game.Players.LocalPlayer.Character.HumanoidRootPart, touch, 0)
                            firetouchinterest(game.Players.LocalPlayer.Character.HumanoidRootPart, touch, 1)
                        end
                    end
                end
            end
        end
    end
end

Main:Button("Auto Collect Money", function()
    if not running and not loopMode then
        running = true
        collectOnce()
        running = false
    elseif not loopMode then
        loopMode = true
        running = true
        task.spawn(function()
            while running do
                collectOnce()
                task.wait(0.5)
            end
        end)
    else
        running = false
        loopMode = false
    end
end)

