local function AutoTake(name)
    local player = game:GetService("Players").LocalPlayer
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")

    local posAkhir = Vector3.new(37.396, 3.495, 37.860)

    local spawner = workspace.ItemSpawners:WaitForChild(name)

    hrp.CFrame = spawner.CFrame + Vector3.new(0,3,0)

    local spawnedItem
    repeat
        spawnedItem = spawner:FindFirstChild("SpawnedItem")
        task.wait(0.25)
    until spawnedItem

    local root = spawnedItem:WaitForChild("RootPart")

    hrp.CFrame = root.CFrame + Vector3.new(0,2,0)

    local prompt = root:FindFirstChildOfClass("ProximityPrompt")
    if not prompt then return end

    fireproximityprompt(prompt)

    task.wait(0.25)

    hrp.CFrame = CFrame.new(posAkhir)
end


Main:Button("Auto Celestial", function()
