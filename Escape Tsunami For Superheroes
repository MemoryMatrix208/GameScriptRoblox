local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/WhoGodsyoure/MyHomeObf/refs/heads/main/Meow"))()

local Window = Library:CreateWindow({
    Title = "Escape Tsunami For Superheroes | ArchiveXNova",
    Accent = Color3.fromRGB(255, 100, 100)
})

local Main = Window:Section("Hero")

local Players = game:GetService("Players")
local Player = Players.LocalPlayer

local function tp(cf)
    local character = Player.Character or Player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    hrp.CFrame = cf
end

Main:Button("Auto Divine", function()

    local posAkhir = CFrame.new(-142.077, 19.495, -422.075)

    local Divine = workspace:FindFirstChild("ItemSpawners")
        and workspace.ItemSpawners:FindFirstChild("Divine")

    if Divine then
        local item = Divine:FindFirstChild("SpawnedItem")
        if item then

            local targetCF

            if item:IsA("Model") then
                targetCF = item:GetPivot()
            elseif item:IsA("BasePart") then
                targetCF = item.CFrame
            end

            if targetCF then
                tp(targetCF + Vector3.new(0, 3, 0))
                task.wait(0.25)

                local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    fireproximityprompt(prompt)
                end

                task.wait(0.25)
                tp(posAkhir)
            end
        end
    end

end)

