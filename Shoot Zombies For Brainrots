local MainTab = Window:CreateTab("Money", "rbxassetid://125367160504472")

local p=game:GetService("Players").LocalPlayer
local rs=game:GetService("RunService")

local mode=0
local conn

local function hrp()
    local c=p.Character or p.CharacterAdded:Wait()
    return c:WaitForChild("HumanoidRootPart")
end

local function collect()
    local r=hrp()
    local plots=workspace:FindFirstChild("Plots")
    if not plots then return end

    for _,plot in pairs(plots:GetChildren()) do
        if plot:IsA("Model") then
            local platforms=plot:FindFirstChild("Platforms")
            if platforms then
                for _,plat in pairs(platforms:GetChildren()) do
                    if plat:IsA("BasePart") then
                        local cash=plat:FindFirstChild("CashPickup")
                        if cash then
                            local hitbox=cash:FindFirstChild("Hitbox")
                            if hitbox and hitbox:IsA("BasePart") then
                                firetouchinterest(r,hitbox,0)
                                firetouchinterest(r,hitbox,1)
                            end
                        end
                    end
                end
            end
        end
    end
end

local function startLoop()
    if conn then conn:Disconnect() end
    conn=rs.Heartbeat:Connect(function()
        collect()
        task.wait(0.1)
    end)
end

local function stopLoop()
    if conn then conn:Disconnect() conn=nil end
end

