local function tp(cf)
    local c=p.Character or p.CharacterAdded:Wait()
    local hrp=c:WaitForChild("HumanoidRootPart")
    hrp.CFrame=cf
end

local function jump()
    local c=p.Character
    if c then
        local h=c:FindFirstChildOfClass("Humanoid")
        if h then
            h:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end

local function collect(areaName)
    if not areaName then return end

    local endPos=CFrame.new(-60.483,18.106,-157.398)

    local map=workspace:FindFirstChild("Map")
    if not map then return end

    local areas=map:FindFirstChild("Areas")
    if not areas then return end

    local area=areas:FindFirstChild(areaName)
    if not area then return end

    local spawns=area:FindFirstChild("Spawns")
    if not spawns then return end

    local part=spawns:FindFirstChild("Part")
    if not part then return end

    local item=part:FindFirstChildWhichIsA("Model")
    if not item then return end

    local base=item:FindFirstChildWhichIsA("BasePart")
    if not base then return end

    tp(base.CFrame+Vector3.new(0,2,0))
    task.wait(speedDelay)

    local pr=item:FindFirstChildWhichIsA("ProximityPrompt",true)
    if pr then
        pcall(function()
            pr.Enabled=true
            pr.HoldDuration=0
            pr.RequiresLineOfSight=false
            pr.MaxActivationDistance=math.huge
            fireproximityprompt(pr)
        end)
    end

    task.wait(speedDelay)
    tp(endPos)
    task.wait(speedDelay)
    jump()
end

local function loop()
    if running then return end
    running=true
    task.spawn(function()
        while running do
            if selectedArea then
                collect(selectedArea)
            end
            task.wait(speedDelay)
        end
    end)
end

local function stop()
    running=false
end

